{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mastoras-site",
  "compatibility_date": "2026-06-03",
  "preview_urls": true,
  "build": {
    "command": "npm run build"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
